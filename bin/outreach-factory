#!/usr/bin/env bash
# outreach-factory — onboarding + operations CLI entrypoint.
#
# Thin shim over orchestrator/cli.py. Prefers the repo virtualenv if present.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [[ -x "$REPO_ROOT/.venv/bin/python3" ]]; then
    PY="$REPO_ROOT/.venv/bin/python3"
else
    PY="python3"
fi

exec "$PY" "$REPO_ROOT/orchestrator/cli.py" "$@"
